# Env vars for MCPs, APIS, etc.

# OpenAI — gpt-image-1 for brand assets (logo, wordmark, hero character); uses reference images in public/brand/
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini
# API Keys for Google AI Studio
# https://aistudio.google.com/api-keys
GEMINI_API_KEY=

# Recraft
# tastefully crafted AI image models
# https://www.recraft.ai/
RECRAFT_API_KEY=

# Neon — dev branch (local). Production uses NEON_DATABASE_URL on Netlify only.
DATABASE_URL=
# Netlify production only (Neon main / muddy) — do not put in .env.local
# NEON_DATABASE_URL=
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Resend — configure same key in Neon console → Auth → Custom SMTP (smtp.resend.com)
RESEND_API_KEY=

# Agent runtimes only (MCP, loop-agent, smoke scripts) — Next.js / Netlify do NOT read these.
# Set in MCP config env or export in the shell before running scripts.
# ETC_API_URL=http://localhost:3000/api/v1
# ETC_API_KEY=
# ETC_STAGE_ID=