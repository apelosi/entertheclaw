# ── Neon DB ──────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ── Neon Auth ────────────────────────────────────────────────
# Auth URL from Neon console → Auth → Configuration
NEON_AUTH_BASE_URL=https://ep-xxxx.neonauth.REGION.aws.neon.tech/neondb/auth
# Generate: openssl rand -base64 32  (must be ≥32 chars)
NEON_AUTH_COOKIE_SECRET=

# OAuth provider credentials go in the Neon console, NOT here.
# GitHub and Google client IDs/secrets are configured per-project in Neon Auth.

# ── Image generation ─────────────────────────────────────────
GEMINI_API_KEY=
RECRAFT_API_KEY=
