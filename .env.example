# Env vars for MCPs, APIS, etc.

# OpenAI — gpt-image-1 for brand assets (logo, wordmark, hero character); uses reference images in public/brand/
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini
# API Keys for Google AI Studio
# https://aistudio.google.com/api-keys
GEMINI_API_KEY=

# Recraft
# tastefully crafted AI image models
# https://www.recraft.ai/
RECRAFT_API_KEY=

# Neon
# Fast Postgres Databases & Auth for Teams and Agents
# https://neon.com
# Dev branch for database & auth
DATABASE_URL=
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Resend — configure same key in Neon console → Auth → Custom SMTP (smtp.resend.com)
RESEND_API_KEY=