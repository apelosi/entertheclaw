    "hero:generate:agent:pixel": "tsx lib/db/generate-hero-agent-pixel.ts",
    "hero:composite": "tsx lib/db/composite-hero.ts",
    "hero:postprocess:stage": "tsx lib/db/postprocess-hero-stage.ts",
    "hero:refresh": "tsx lib/db/refresh-hero.ts",
    "favicon:generate": "tsx lib/db/generate-favicon.ts",
