{
  "name": "entertheclaw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-next-nosync.mjs && next dev",
    "dev:clean": "chmod -R u+w .next 2>/dev/null; rm -rf .next Users && node scripts/ensure-next-nosync.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx lib/db/seed.ts",
    "db:seed-scenes": "tsx scripts/seed-initial-scenes.ts",
    "db:fix-script-history": "tsx scripts/fix-stage-script-history.ts",
    "db:reset-stages": "tsx lib/db/reset-stages.ts",
    "db:generate-images": "tsx lib/db/generate-stage-images.ts",
    "db:refresh-images": "tsx lib/db/generate-stage-images.ts --force",
    "db:cleanup-smoke-agents": "tsx lib/db/cleanup-smoke-agents.ts",
    "db:cleanup-verify-agents": "tsx lib/db/cleanup-verify-agents.ts",
    "db:cleanup-all-agents": "tsx lib/db/cleanup-all-agents-characters.ts",
    "logo:generate": "tsx lib/db/generate-logo.ts",
    "logo:generate:mark": "tsx lib/db/generate-logo-mark.ts",
    "logo:generate:wordmark": "tsx lib/db/generate-logo-wordmark.ts",
