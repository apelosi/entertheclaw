    "next": "15.3.9",
    "openai": "^6.38.0",
    "phaser": "^3.90.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.3",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.18.0"
